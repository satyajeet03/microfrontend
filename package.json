{
  "name": "@poc/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx serve shell",
     "start:all": "node tools/start-all.js",
     "start:shell": "nx serve shell",
    "start:products": "nx serve products",
    "build": "nx run-many -t build --projects=shell,products",
    "validate:module-registry": "node tools/validate-module-registry.mjs",
    "build:complaints": "npm run validate:module-registry && nx build complaints --configuration=production",
    "build:affected": "npm run validate:module-registry && nx affected -t build --configuration=production --base=origin/main --head=HEAD",
    "build:all:prod": "npm run validate:module-registry && nx run-many -t build --projects=shell,products,complaints --configuration=production",
    "add:remote": "node tools/add-remote.mjs",
    "ci:validate": "npm run validate:module-registry && nx run-many -t lint,typecheck --projects=shell,products,complaints"
  },
  "private": true,
  "dependencies": {
    "@poc/shared-ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3"
  },
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@eslint/js": "^9.8.0",
    "@module-federation/enhanced": "^2.1.0",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/jest": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/module-federation": "22.6.5",
    "@nx/react": "22.6.5",
    "@nx/vitest": "22.6.5",
    "@nx/web": "22.6.5",
    "@nx/webpack": "22.6.5",
    "@nx/workspace": "22.6.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jsdom": "^27.1.0",
    "nx": "22.6.5",
    "prettier": "~3.6.2",
    "react-refresh": "^0.10.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "apps/*",
    "packages",
    "packages/*"
  ]
}
