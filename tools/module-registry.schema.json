{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poc.local/schemas/module-registry.schema.json",
  "title": "Portal Module Registry",
  "type": "object",
  "required": ["modules"],
  "additionalProperties": false,
  "properties": {
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "displayName",
          "routePath",
          "remoteName",
          "entry",
          "exposedModule",
          "source",
          "enabled",
          "stateCodes"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "displayName": {
            "type": "string",
            "minLength": 2
          },
          "routePath": {
            "type": "string",
            "pattern": "^/[a-z0-9-]*(?:/[a-z0-9-]+)*$"
          },
          "matchMode": {
            "type": "string",
            "enum": ["exact", "prefix"]
          },
          "remoteName": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]*$"
          },
          "entry": {
            "type": "string",
            "pattern": "^(https?://|http?://localhost:)[^\\s]+remoteEntry\\.js$"
          },
          "exposedModule": {
            "type": "string",
            "pattern": "^(\\.?/?[A-Za-z0-9_-]+)$"
          },
          "source": {
            "type": "string",
            "enum": ["workspace", "external"]
          },
          "enabled": {
            "type": "boolean"
          },
          "stateCodes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
